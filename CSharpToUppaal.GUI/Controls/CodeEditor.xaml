<!-- Controls/CodeEditor.xaml -->
<UserControl x:Class="CSharpToUppaal.GUI.Controls.CodeEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit">
    <Grid>
        <avalonEdit:TextEditor x:Name="editor"
                               Text="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               IsReadOnly="{Binding RelativeSource={RelativeSource AncestorType=UserControl}, Path=IsReadOnly}"
                               FontFamily="Consolas"
                               FontSize="12"
                               ShowLineNumbers="True"
                               WordWrap="False"
                               HorizontalScrollBarVisibility="Auto"
                               VerticalScrollBarVisibility="Auto"/>
    </Grid>
</UserControl>