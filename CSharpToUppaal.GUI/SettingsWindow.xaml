<!-- SettingsWindow.xaml -->
<Window x:Class="CSharpToUppaal.GUI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="400" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Application Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="UPPAAL verifyta Path:" Margin="0,0,0,5"/>
            <TextBox x:Name="VerifytaPathTextBox" Margin="0,0,0,15"/>

            <CheckBox x:Name="EnableAutoSaveCheckBox" Content="Enable Auto-save" Margin="0,0,0,10"/>
            <CheckBox x:Name="ShowLineNumbersCheckBox" Content="Show Line Numbers in Editor" IsChecked="True" Margin="0,0,0,10"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" IsDefault="True" Click="OkButton_Click" Margin="0,0,10,0"/>
            <Button Content="Cancel" Width="80" IsCancel="True" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>