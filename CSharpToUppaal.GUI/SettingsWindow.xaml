<Window x:Class="CSharpToUppaal.GUI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="430" Width="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">
    <Grid Margin="20" Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Application Settings" FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

            <CheckBox x:Name="OllamaEnabledCheckBox"
                      Content="Enable local Ollama requirement translation"
                      Margin="0,0,0,12"/>

            <TextBlock Text="Ollama API Base URL:" Margin="0,0,0,5"/>
            <TextBox x:Name="OllamaBaseUrlTextBox" Margin="0,0,0,14"/>

            <TextBlock Text="Ollama Model:" Margin="0,0,0,5"/>
            <TextBox x:Name="OllamaModelTextBox" Margin="0,0,0,14"/>

            <TextBlock Text="Ollama Timeout Seconds:" Margin="0,0,0,5"/>
            <TextBox x:Name="OllamaTimeoutTextBox" Margin="0,0,0,14"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" IsDefault="True" Click="OkButton_Click" Margin="0,0,10,0"
                    Style="{StaticResource MaterialDesignRaisedButton}"/>
            <Button Content="Cancel" Width="80" IsCancel="True" Click="CancelButton_Click"
                    Style="{StaticResource MaterialDesignRaisedButton}"/>
        </StackPanel>
    </Grid>
</Window>
