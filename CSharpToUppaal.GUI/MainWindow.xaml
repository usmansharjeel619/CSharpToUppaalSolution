<Window x:Class="CSharpToUppaal.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CSharpToUppaal.GUI"
        xmlns:vm="clr-namespace:CSharpToUppaal.GUI.ViewModels"
        xmlns:controls="clr-namespace:CSharpToUppaal.GUI.Controls"
        xmlns:converters="clr-namespace:CSharpToUppaal.GUI.Converters"
        xmlns:models="clr-namespace:CSharpToUppaal.Backend.Models;assembly=CSharpToUppaal.Backend"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d"
        Title="C# to UPPAAL Model Generator" 
        Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:NullToVisibilityConverter x:Key="NullToVis" />
        <converters:StatusToColorConverter x:Key="StatusToColor" />
        <converters:BoolToStringConverter x:Key="BoolToStringConverter" />
        <ObjectDataProvider x:Key="FunctionModeValues"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:FunctionModelingMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        
        <!-- Button Style with White Foreground -->
        <Style x:Key="WhiteButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryMidBrush}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Simplified Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" 
                          Text="C# to UPPAAL Model Generator" 
                          FontSize="20" FontWeight="Bold" 
                          Foreground="White" 
                          VerticalAlignment="Center" 
                          Margin="8,0"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Settings" 
                            Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource WhiteButtonStyle}"
                            Margin="8,0"/>
                    <Button Content="Clear All" 
                            Command="{Binding ClearAllCommand}"
                            Style="{StaticResource WhiteButtonStyle}"
                            Margin="8,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content Area (No Left Panel) -->
        <TabControl Grid.Row="1" 
                   Background="{StaticResource BackgroundBrush}"
                   BorderThickness="0">

            <!-- Code Editor Tab -->
            <TabItem Header="Code Editor">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="90"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar with white buttons -->
                    <StackPanel Grid.Row="0" 
                               Orientation="Horizontal" 
                               Background="{StaticResource PrimaryMidBrush}">
                        <Button Content="Load File" 
                                Command="{Binding LoadFileCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="8"/>
                        <Button Content="Parse" 
                                Command="{Binding ParseCodeCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="4"/>
                        <Button Content="Clear All" 
                                Command="{Binding ClearCodeCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="4"/>
                    </StackPanel>

                    <controls:CodeEditor Grid.Row="1" 
                                       Text="{Binding SourceCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>

            <!-- Function Selection Tab -->
            <TabItem Header="Functions">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Background="{StaticResource PrimaryMidBrush}">
                        <Button Content="Analyze Functions"
                                Command="{Binding RunAnalysisCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="8"/>
                        <TextBlock Text="{Binding GenerationReportText}"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="12,0"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding FunctionSelections}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Use" Binding="{Binding IsSelected, Mode=TwoWay}" Width="60"/>
                            <DataGridTextColumn Header="Function" Binding="{Binding Name}" Width="220" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Signature" Binding="{Binding Signature}" Width="280" IsReadOnly="True"/>
                            <DataGridComboBoxColumn Header="Mode"
                                                    SelectedItemBinding="{Binding Mode, Mode=TwoWay}"
                                                    ItemsSource="{Binding Source={StaticResource FunctionModeValues}}"
                                                    Width="150"/>
                            <DataGridTextColumn Header="Return" Binding="{Binding ReturnType}" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Parameters" Binding="{Binding Parameters}" Width="220" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Calls" Binding="{Binding DependencyCount}" Width="70" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Warnings" Binding="{Binding Warnings}" Width="*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2"
                               Text="{Binding SettingsSummary}"
                               Foreground="White"
                               Margin="10,6"/>
                </Grid>
            </TabItem>

            <!-- CFG Visualization Tab -->
            <TabItem Header="CFG Visualization">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="120"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar with white buttons -->
                    <StackPanel Grid.Row="0" 
                               Orientation="Horizontal" 
                               Background="{StaticResource PrimaryMidBrush}"
                               >
                        <Button Content="Generate CFG" 
                                Command="{Binding GenerateCfgCommand}"
                                Style="{StaticResource WhiteButtonStyle}"/>
                        <Button Content="Export CFG (PNG)" 
                                Command="{Binding ExportCfgPngCommand}"
                                Style="{StaticResource WhiteButtonStyle}"/>
                        <Separator Margin="8,0" Background="White" Width="2"/>
                        <TextBlock Text="Method:" 
                                 VerticalAlignment="Center" 
                                 Margin="8,0"
                                 Foreground="White"
                                 FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding Methods}" 
                                SelectedItem="{Binding SelectedMethod}"
                                DisplayMemberPath="Name" 
                                Width="250"
                                VerticalAlignment="Center"
                                Background="{StaticResource SurfaceBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" 
                                HorizontalScrollBarVisibility="Auto" 
                                VerticalScrollBarVisibility="Auto"
                                Background="{StaticResource BackgroundBrush}">
                        <Border Background="{StaticResource SurfaceBrush}" 
                               Margin="20" 
                               BorderBrush="{StaticResource BorderBrush}" 
                               BorderThickness="1"
                               CornerRadius="4">
                            <Canvas x:Name="CfgCanvas" 
                                   Width="800" 
                                   Height="600" 
                                   Background="{StaticResource SurfaceBrush}"/>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- UPPAAL Model Tab -->
            <TabItem Header="UPPAAL Model">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar with white buttons -->
                    <StackPanel Grid.Row="0" 
                               Orientation="Horizontal" 
                               Background="{StaticResource PrimaryMidBrush}"
                               >
                        <Button Content="Generate UPPAAL Model" 
                                Command="{Binding GenerateModelCommand}"
                                Style="{StaticResource WhiteButtonStyle}"/>
                        <Button Content="Export" 
                                Command="{Binding ExportModelCommand}"
                                Style="{StaticResource WhiteButtonStyle}"/>
                        <Separator Margin="8,0" Background="White" Width="2"/>
                        <TextBlock Text="{Binding ReadinessStatus}"
                                 VerticalAlignment="Center"
                                 Margin="8,0"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 FontWeight="SemiBold"/>
                        <Separator Margin="8,0" Background="White" Width="2"/>
                        <TextBlock Text="Model Name:" 
                                 VerticalAlignment="Center" 
                                 Margin="8,0"
                                 Foreground="White"
                                 FontWeight="SemiBold"/>
                        <TextBox Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}" 
                               Width="200"
                               VerticalAlignment="Center"
                               Padding="6,4"
                               Background="{StaticResource SurfaceBrush}"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <TabControl Grid.Row="1" 
                               Background="{StaticResource BackgroundBrush}"
                               BorderThickness="0">
                        <!-- XML View -->
                        <TabItem Header="XML View">
                            <TextBox FontFamily="Consolas" 
                                   FontSize="12"
                                   Text="{Binding UppaalXml, Mode=TwoWay}"
                                   AcceptsReturn="True" 
                                   AcceptsTab="True"
                                   VerticalScrollBarVisibility="Auto"
                                   HorizontalScrollBarVisibility="Auto"
                                   IsReadOnly="{Binding IsXmlReadOnly}"
                                   Background="{StaticResource SurfaceBrush}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Padding="10"/>
                        </TabItem>
                        <TabItem Header="Readiness">
                            <Grid Background="{StaticResource BackgroundBrush}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="{Binding ReadinessStatus}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           Margin="10,8"/>
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding CompatibilityIssues}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          Margin="8">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="100"/>
                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="150"/>
                                        <DataGridTextColumn Header="Position" Binding="{Binding Position}" Width="260"/>
                                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>

            <!-- Requirements Tab -->
            <TabItem Header="Requirements">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="180"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Background="{StaticResource PrimaryMidBrush}">
                        <Button Content="Interpret Requirements"
                                Command="{Binding InterpretRequirementsCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="8"/>
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             FontFamily="Consolas"
                             FontSize="13"
                             Text="{Binding RequirementsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Padding="10"
                             Margin="8"/>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding GeneratedQueries}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Margin="8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="170"/>
                            <DataGridTextColumn Header="Formula" Binding="{Binding Formula}" Width="360"/>
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="90" IsReadOnly="True"/>
                            <DataGridCheckBoxColumn Header="Valid" Binding="{Binding IsValidated}" Width="70" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Comment" Binding="{Binding Comment}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Analysis Results Tab -->
            <TabItem Header="Analysis">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar with white buttons -->
                    <StackPanel Grid.Row="0" 
                               Orientation="Horizontal" 
                               Background="{StaticResource PrimaryMidBrush}"
                               >
                        <Button Content="Run Analysis" 
                                Command="{Binding RunAnalysisCommand}"
                                Style="{StaticResource WhiteButtonStyle}"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ListBox Grid.Column="0" 
                               ItemsSource="{Binding Methods}"
                               SelectedItem="{Binding SelectedMethod}"
                               Background="{StaticResource BackgroundBrush}"
                               Foreground="{StaticResource TextPrimaryBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="8">
                                        <TextBlock Text="{Binding Name}" 
                                                 FontWeight="Bold"
                                                 FontSize="14"
                                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding ReturnType}" 
                                                 FontStyle="Italic"
                                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="Complexity: " 
                                                     FontWeight="SemiBold"
                                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding Complexity.CyclomaticComplexity}"
                                                     FontWeight="Bold"
                                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Column="1" 
                              BorderBrush="{StaticResource BorderBrush}" 
                              BorderThickness="1,0,0,0"
                              Background="{StaticResource SurfaceBrush}">
                            <ScrollViewer>
                                <StackPanel Margin="16" DataContext="{Binding SelectedMethod}">
                                    <TextBlock Text="Method Details" 
                                             FontSize="18" 
                                             FontWeight="Bold" 
                                             Margin="0,0,0,16"
                                             Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,10">
                                            <Run Text="Name: " 
                                                 FontWeight="SemiBold" 
                                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <Run Text="{Binding Name, Mode=OneWay}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,10">
                                            <Run Text="Return Type: " 
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <Run Text="{Binding ReturnType, Mode=OneWay}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,10">
                                            <Run Text="Cyclomatic Complexity: " 
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <Run Text="{Binding Complexity.CyclomaticComplexity, Mode=OneWay}"
                                                 FontWeight="Bold"
                                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,10">
                                            <Run Text="Lines of Code: " 
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <Run Text="{Binding LinesOfCode, Mode=OneWay}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Assumptions and Domains Tab -->
            <TabItem Header="Assumptions">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Grid.Row="0" Header="Translation Assumptions" Foreground="White" Margin="8">
                        <DataGrid ItemsSource="{Binding Assumptions}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="150" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Symbol" Binding="{Binding SymbolName}" Width="220" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="220" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <GroupBox Grid.Row="1" Header="Variable Domains" Foreground="White" Margin="8">
                        <DataGrid ItemsSource="{Binding Domains}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="260"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="90"/>
                                <DataGridTextColumn Header="Min" Binding="{Binding Min}" Width="80"/>
                                <DataGridTextColumn Header="Max" Binding="{Binding Max}" Width="80"/>
                                <DataGridCheckBoxColumn Header="Bool" Binding="{Binding IsBoolean}" Width="70"/>
                                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- Layout Fixer Tab -->
            <TabItem Header="Layout Fixer">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <StackPanel Grid.Row="0" 
                               Orientation="Horizontal" 
                               Background="{StaticResource PrimaryMidBrush}">
                        <Button Content="Load XML File" 
                                Command="{Binding LoadLayoutInputCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                ToolTip="Open a UPPAAL XML file to fix"/>
                        <Button Content="Fix Layout" 
                                Command="{Binding FixLayoutCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                ToolTip="Re-compute positions for the input XML"/>
                        <Button Content="Export Fixed XML" 
                                Command="{Binding ExportFixedLayoutCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                ToolTip="Save the corrected XML to a file"/>
                        <Separator Margin="8,0" Background="White" Width="2"/>
                        <Button Content="Clear" 
                                Command="{Binding ClearLayoutCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                ToolTip="Clear both panels"/>
                    </StackPanel>

                    <!-- Two-panel layout: Input (left) → Output (right) -->
                    <Grid Grid.Row="1" Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Input panel -->
                        <DockPanel Grid.Column="0">
                            <TextBlock DockPanel.Dock="Top" 
                                     Text="Input XML (paste or load a jumbled UPPAAL model)" 
                                     FontWeight="SemiBold" Foreground="White"
                                     Margin="8,6,8,4"/>
                            <TextBox FontFamily="Consolas" FontSize="12"
                                   Text="{Binding LayoutInputXml, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   AcceptsReturn="True" AcceptsTab="True"
                                   VerticalScrollBarVisibility="Auto"
                                   HorizontalScrollBarVisibility="Auto"
                                   Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                   Padding="10" Margin="4"/>
                        </DockPanel>

                        <!-- Arrow separator -->
                        <TextBlock Grid.Column="1" Text="➜" 
                                 FontSize="28" FontWeight="Bold"
                                 Foreground="{StaticResource PrimaryMidBrush}"
                                 VerticalAlignment="Center" 
                                 Margin="6,0"/>

                        <!-- Output panel -->
                        <DockPanel Grid.Column="2">
                            <TextBlock DockPanel.Dock="Top" 
                                     Text="Output XML (fixed layout)" 
                                     FontWeight="SemiBold" Foreground="White"
                                     Margin="8,6,8,4"/>
                            <TextBox FontFamily="Consolas" FontSize="12"
                                   Text="{Binding LayoutOutputXml, Mode=TwoWay}"
                                   AcceptsReturn="True" AcceptsTab="True"
                                   VerticalScrollBarVisibility="Auto"
                                   HorizontalScrollBarVisibility="Auto"
                                   IsReadOnly="True"
                                   Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                   Padding="10" Margin="4"/>
                        </DockPanel>
                    </Grid>

                    <TextBox Grid.Row="2"
                             Text="{Binding LayoutReportText}"
                             IsReadOnly="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             VerticalScrollBarVisibility="Auto"
                             Margin="8"
                             Padding="8"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" 
                  Background="{StaticResource PrimaryDarkBrush}" 
                  Foreground="White"
                  Height="30">
            <StatusBarItem>
                <TextBlock Foreground="White">
                    <Run Text="Status: "/>
                    <Run Text="{Binding StatusMessage}" FontWeight="SemiBold"/>
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <ProgressBar Width="120" Height="18" 
                           IsIndeterminate="{Binding IsBusy}"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                           Foreground="#FFD700"/>
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Foreground="White">
                    <Run Text="Project: "/>
                    <Run Text="{Binding CurrentProjectName}" FontWeight="SemiBold"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
