<Window x:Class="CSharpToUppaal.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CSharpToUppaal.GUI"
        xmlns:vm="clr-namespace:CSharpToUppaal.GUI.ViewModels"
        xmlns:controls="clr-namespace:CSharpToUppaal.GUI.Controls"
        xmlns:converters="clr-namespace:CSharpToUppaal.GUI.Converters"
        mc:Ignorable="d"
        Title="C# to UPPAAL Model Generator" 
        Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:NullToVisibilityConverter x:Key="NullToVis" />
        <converters:StatusToColorConverter x:Key="StatusToColor" />
        <converters:BoolToStringConverter x:Key="BoolToStringConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with Menu -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" Padding="8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Text="C# to UPPAAL Model Generator" 
                         FontSize="18" FontWeight="SemiBold" 
                         Foreground="{StaticResource TextPrimaryBrush}" 
                         VerticalAlignment="Center" Margin="8,0"/>

                <Menu DockPanel.Dock="Right" Background="Transparent" 
                      Foreground="{StaticResource TextPrimaryBrush}" 
                      VerticalAlignment="Center">
                    <MenuItem Header="File">
                        <MenuItem Header="New Project" Command="{Binding NewProjectCommand}"/>
                        <MenuItem Header="Open C# File..." Command="{Binding OpenFileCommand}"/>
                        <Separator />
                        <MenuItem Header="Save UPPAAL Model..." Command="{Binding SaveModelCommand}"/>
                        <Separator />
                        <MenuItem Header="Exit" Command="{Binding ExitCommand}"/>
                    </MenuItem>

                    <MenuItem Header="Edit">
                        <MenuItem Header="Generate CFG" Command="{Binding GenerateCfgCommand}"/>
                        <MenuItem Header="Generate UPPAAL Model" Command="{Binding GenerateModelCommand}"/>
                        <MenuItem Header="Verify Model" Command="{Binding VerifyModelCommand}"/>
                    </MenuItem>

                    <MenuItem Header="View">
                        <MenuItem Header="Show CFG Visualization" Command="{Binding ShowCfgCommand}"/>
                        <MenuItem Header="Show UPPAAL Model" Command="{Binding ShowModelCommand}"/>
                        <MenuItem Header="Show Verification Results" Command="{Binding ShowVerificationCommand}"/>
                    </MenuItem>

                    <MenuItem Header="Tools">
                        <MenuItem Header="Settings" Command="{Binding OpenSettingsCommand}"/>
                        <MenuItem Header="Clear All" Command="{Binding ClearAllCommand}"/>
                    </MenuItem>

                    <MenuItem Header="Help">
                        <MenuItem Header="Documentation" Command="{Binding ShowHelpCommand}"/>
                        <MenuItem Header="About" Command="{Binding ShowAboutCommand}"/>
                    </MenuItem>
                </Menu>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Project Explorer -->
            <Border Grid.Column="0" 
                    Background="{StaticResource SurfaceBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" 
                            Background="{StaticResource PrimaryMidBrush}" 
                            Padding="8">
                        <TextBlock Text="Project Explorer" 
                                 FontSize="14" FontWeight="SemiBold" 
                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Border>

                    <TreeView ItemsSource="{Binding ProjectItems}"
                              Background="{StaticResource SurfaceBrush}"
                              Foreground="{StaticResource TextPrimaryBrush}">
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                <TextBlock Text="{Binding Name}" 
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         Padding="4,2"/>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" 
                         HorizontalAlignment="Stretch" 
                         Background="{StaticResource BorderBrush}"/>

            <!-- Right Panel - Tab Content -->
            <TabControl Grid.Column="2" 
                       Background="{StaticResource BackgroundBrush}"
                       BorderThickness="0">

                <!-- Code Editor Tab -->
                <TabItem Header="Code Editor">
                    <Grid Background="{StaticResource BackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ToolBar Grid.Row="0" 
                                Background="{StaticResource PrimaryMidBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}">
                            <Button Content="Load File" Command="{Binding LoadFileCommand}"/>
                            <Separator />
                            <Button Content="Parse" Command="{Binding ParseCodeCommand}"/>
                            <Button Content="Analyze" Command="{Binding AnalyzeCodeCommand}"/>
                        </ToolBar>

                        <controls:CodeEditor Grid.Row="1" 
                                           Text="{Binding SourceCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </TabItem>

                <!-- CFG Visualization Tab -->
                <TabItem Header="CFG Visualization">
                    <Grid Background="{StaticResource BackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ToolBar Grid.Row="0"
                                Background="{StaticResource PrimaryMidBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}">
                            <Button Content="Generate CFG" Command="{Binding GenerateCfgCommand}"/>
                            <Button Content="Export as DOT" Command="{Binding ExportDotCommand}"/>
                            <Separator />
                            <TextBlock Text="Method:" 
                                     VerticalAlignment="Center" 
                                     Margin="4,0"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                            <ComboBox ItemsSource="{Binding Methods}" 
                                    SelectedItem="{Binding SelectedMethod}"
                                    DisplayMemberPath="Name" 
                                    Width="200"
                                    Background="{StaticResource SurfaceBrush}"
                                    Foreground="{StaticResource TextPrimaryBrush}">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                            </ComboBox>
                        </ToolBar>

                        <ScrollViewer Grid.Row="1" 
                                    HorizontalScrollBarVisibility="Auto" 
                                    VerticalScrollBarVisibility="Auto"
                                    Background="{StaticResource BackgroundBrush}">
                            <Border Background="White" Margin="10">
                                <Canvas x:Name="CfgCanvas" Width="800" Height="600" Background="White"/>
                            </Border>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <!-- UPPAAL Model Tab -->
                <TabItem Header="UPPAAL Model">
                    <Grid Background="{StaticResource BackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ToolBar Grid.Row="0"
                                Background="{StaticResource PrimaryMidBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}">
                            <Button Content="Generate Model" Command="{Binding GenerateModelCommand}"/>
                            <Button Content="Verify" Command="{Binding VerifyModelCommand}"/>
                            <Button Content="Export" Command="{Binding ExportModelCommand}"/>
                            <Separator />
                            <TextBlock Text="Model Name:" 
                                     VerticalAlignment="Center" 
                                     Margin="4,0"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBox Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}" 
                                   Width="200"/>
                        </ToolBar>

                        <TextBox Grid.Row="1" 
                               FontFamily="Consolas" 
                               FontSize="12"
                               Text="{Binding UppaalXml, Mode=TwoWay}"
                               AcceptsReturn="True" 
                               AcceptsTab="True"
                               VerticalScrollBarVisibility="Auto"
                               HorizontalScrollBarVisibility="Auto"
                               IsReadOnly="{Binding IsXmlReadOnly}"
                               Background="{StaticResource BackgroundBrush}"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Grid>
                </TabItem>

                <!-- Verification Results Tab -->
                <TabItem Header="Verification Results">
                    <Grid Background="{StaticResource BackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ToolBar Grid.Row="0"
                                Background="{StaticResource PrimaryMidBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}">
                            <Button Content="Run Verification" Command="{Binding RunVerificationCommand}"/>
                            <Button Content="Clear Results" Command="{Binding ClearVerificationCommand}"/>
                            <Separator />
                            <TextBlock Text="Status:" 
                                     VerticalAlignment="Center" 
                                     Margin="4,0"
                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding VerificationStatus}" 
                                     VerticalAlignment="Center" 
                                     FontWeight="Bold" 
                                     Margin="4,0"
                                     Foreground="{StaticResource AccentBrush}"/>
                        </ToolBar>

                        <DataGrid Grid.Row="1" 
                                ItemsSource="{Binding VerificationResults}"
                                AutoGenerateColumns="False" 
                                IsReadOnly="True"
                                Background="{StaticResource BackgroundBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Property" Binding="{Binding Name}" Width="150"/>
                                <DataGridTextColumn Header="Formula" Binding="{Binding Formula}" Width="300"/>
                                <DataGridCheckBoxColumn Header="Verified" Binding="{Binding IsVerified}" Width="80"/>
                                <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="200"/>
                                <DataGridTextColumn Header="Time" Width="80">
                                    <DataGridTextColumn.Binding>
                                        <Binding Path="VerificationTime" StringFormat="{}{0:mm\\:ss\\.fff}"/>
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Error" Binding="{Binding ErrorMessage}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <!-- Analysis Results Tab -->
                <TabItem Header="Analysis">
                    <Grid Background="{StaticResource BackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <ToolBar Grid.Row="0"
                                Background="{StaticResource PrimaryMidBrush}"
                                Foreground="{StaticResource TextPrimaryBrush}">
                            <Button Content="Run Analysis" Command="{Binding RunAnalysisCommand}"/>
                        </ToolBar>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <ListBox Grid.Column="0" 
                                   ItemsSource="{Binding Methods}"
                                   SelectedItem="{Binding SelectedMethod}"
                                   Background="{StaticResource BackgroundBrush}"
                                   Foreground="{StaticResource TextPrimaryBrush}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4">
                                            <TextBlock Text="{Binding Name}" 
                                                     FontWeight="Bold"
                                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding ReturnType}" 
                                                     FontStyle="Italic"
                                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Complexity: " 
                                                         FontWeight="SemiBold"
                                                         Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding Complexity.CyclomaticComplexity}"
                                                         Foreground="{StaticResource AccentBrush}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <Border Grid.Column="1" 
                                  BorderBrush="{StaticResource BorderBrush}" 
                                  BorderThickness="1,0,0,0"
                                  Background="{StaticResource SurfaceBrush}">
                                <ScrollViewer>
                                    <StackPanel Margin="12" DataContext="{Binding SelectedMethod}">
                                        <TextBlock Text="Method Details" 
                                                 FontSize="16" 
                                                 FontWeight="SemiBold" 
                                                 Margin="0,0,0,12"
                                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <StackPanel>
                                            <TextBlock Margin="0,0,0,8">
                                                <Run Text="Name: " 
                                                     FontWeight="SemiBold" 
                                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <Run Text="{Binding Name, Mode=OneWay}"
                                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </TextBlock>
                                            <TextBlock Margin="0,0,0,8">
                                                <Run Text="Return Type: " 
                                                     FontWeight="SemiBold"
                                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <Run Text="{Binding ReturnType, Mode=OneWay}"
                                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </TextBlock>
                                            <TextBlock Margin="0,0,0,8">
                                                <Run Text="Cyclomatic Complexity: " 
                                                     FontWeight="SemiBold"
                                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <Run Text="{Binding Complexity.CyclomaticComplexity, Mode=OneWay}"
                                                     Foreground="{StaticResource AccentBrush}"/>
                                            </TextBlock>
                                            <TextBlock Margin="0,0,0,8">
                                                <Run Text="Lines of Code: " 
                                                     FontWeight="SemiBold"
                                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                                                <Run Text="{Binding LinesOfCode, Mode=OneWay}"
                                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" 
                  Background="{StaticResource PrimaryDarkBrush}" 
                  Foreground="{StaticResource TextPrimaryBrush}"
                  Height="28">
            <StatusBarItem>
                <TextBlock>
                    <Run Text="Status: "/>
                    <Run Text="{Binding StatusMessage}" FontWeight="SemiBold"/>
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <ProgressBar Width="100" Height="16" 
                           IsIndeterminate="{Binding IsBusy}"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                           Foreground="{StaticResource AccentBrush}"/>
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock>
                    <Run Text="Project: "/>
                    <Run Text="{Binding CurrentProjectName}" FontWeight="SemiBold"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>