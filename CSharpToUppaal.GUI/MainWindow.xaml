<Window x:Class="CSharpToUppaal.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CSharpToUppaal.GUI"
        xmlns:vm="clr-namespace:CSharpToUppaal.GUI.ViewModels"
        xmlns:controls="clr-namespace:CSharpToUppaal.GUI.Controls"
        xmlns:converters="clr-namespace:CSharpToUppaal.GUI.Converters"
        xmlns:models="clr-namespace:CSharpToUppaal.Backend.Models;assembly=CSharpToUppaal.Backend"
        xmlns:sys="clr-namespace:System;assembly=System.Runtime"
        mc:Ignorable="d"
        Title="C# to UPPAAL Model Generator"
        Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:NullToVisibilityConverter x:Key="NullToVis" />
        <converters:StatusToColorConverter x:Key="StatusToColor" />
        <converters:BoolToStringConverter x:Key="BoolToStringConverter" />
        <ObjectDataProvider x:Key="FunctionModeValues"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:FunctionModelingMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <Style x:Key="WhiteButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryMidBrush}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                          Text="C# to UPPAAL Model Generator"
                          FontSize="20" FontWeight="Bold"
                          Foreground="White"
                          VerticalAlignment="Center"
                          Margin="8,0"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Settings"
                            Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource WhiteButtonStyle}"
                            Margin="8,0"/>
                    <Button Content="Clear All"
                            Command="{Binding ClearAllCommand}"
                            Style="{StaticResource WhiteButtonStyle}"
                            Margin="8,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Tab order follows the user workflow:
             1. Code Editor  2. Functions  3. UPPAAL Model  4. Model Info
             5. Requirements  6. CFG Visualization  7. Analysis  8. Layout Fixer -->
        <TabControl Grid.Row="1"
                   Background="{StaticResource BackgroundBrush}"
                   BorderThickness="0">

            <!-- ═══════════════════════════════════════════════════
                 1. CODE EDITOR  – load / write C# source
                 ═══════════════════════════════════════════════════ -->
            <TabItem Header="Code Editor">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                               Orientation="Horizontal"
                               Background="{StaticResource PrimaryMidBrush}">
                        <Button Content="Load File"
                                Command="{Binding LoadFileCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="8"/>
                        <Button Content="Parse"
                                Command="{Binding ParseCodeCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="4"/>
                        <Button Content="Clear All"
                                Command="{Binding ClearAllCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="4"/>
                    </StackPanel>

                    <controls:CodeEditor Grid.Row="1"
                                       Text="{Binding SourceCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════
                 2. FUNCTIONS  – select which functions to include
                 ═══════════════════════════════════════════════════ -->
            <TabItem Header="Functions">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Background="{StaticResource PrimaryMidBrush}">
                        <Button Content="Analyze Functions"
                                Command="{Binding RunAnalysisCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="8"/>
                        <Button Content="Select All"
                                Command="{Binding SelectAllFunctionsCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="4,8"/>
                        <Button Content="Deselect All"
                                Command="{Binding DeselectAllFunctionsCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="4,8"/>
                        <TextBlock Text="{Binding GenerationReportText}"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="12,0"/>
                    </StackPanel>

                    <!-- Checked functions will be used for CFG and UPPAAL model generation -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding FunctionSelections}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Header="Include" Binding="{Binding IsSelected, Mode=TwoWay}" Width="70"/>
                            <DataGridTextColumn Header="Function" Binding="{Binding Name}" Width="220" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Signature" Binding="{Binding Signature}" Width="280" IsReadOnly="True"/>
                            <DataGridComboBoxColumn Header="Mode"
                                                    SelectedItemBinding="{Binding Mode, Mode=TwoWay}"
                                                    ItemsSource="{Binding Source={StaticResource FunctionModeValues}}"
                                                    Width="150"/>
                            <DataGridTextColumn Header="Return" Binding="{Binding ReturnType}" Width="100" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Parameters" Binding="{Binding Parameters}" Width="220" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Calls" Binding="{Binding DependencyCount}" Width="70" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Warnings" Binding="{Binding Warnings}" Width="*" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2"
                               Text="{Binding SettingsSummary}"
                               Foreground="White"
                               Margin="10,6"/>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════
                 3. UPPAAL MODEL  – generate, review and export
                 ═══════════════════════════════════════════════════ -->
            <TabItem Header="UPPAAL Model">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                               Orientation="Horizontal"
                               Background="{StaticResource PrimaryMidBrush}">
                        <Button Content="Generate UPPAAL Model"
                                Command="{Binding GenerateModelCommand}"
                                Style="{StaticResource WhiteButtonStyle}"/>
                        <Button Content="Export"
                                Command="{Binding ExportModelCommand}"
                                Style="{StaticResource WhiteButtonStyle}"/>
                        <Separator Margin="8,0" Background="White" Width="2"/>
                        <TextBlock Text="{Binding ReadinessStatus}"
                                 VerticalAlignment="Center"
                                 Margin="8,0"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 FontWeight="SemiBold"/>
                        <Separator Margin="8,0" Background="White" Width="2"/>
                        <TextBlock Text="Model Name:"
                                 VerticalAlignment="Center"
                                 Margin="8,0"
                                 Foreground="White"
                                 FontWeight="SemiBold"/>
                        <TextBox Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}"
                               Width="200"
                               VerticalAlignment="Center"
                               Padding="6,4"
                               Background="{StaticResource SurfaceBrush}"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <TabControl Grid.Row="1"
                               Background="{StaticResource BackgroundBrush}"
                               BorderThickness="0">
                        <TabItem Header="XML View">
                            <TextBox FontFamily="Consolas"
                                   FontSize="12"
                                   Text="{Binding UppaalXml, Mode=TwoWay}"
                                   AcceptsReturn="True"
                                   AcceptsTab="True"
                                   VerticalScrollBarVisibility="Auto"
                                   HorizontalScrollBarVisibility="Auto"
                                   IsReadOnly="{Binding IsXmlReadOnly}"
                                   Background="{StaticResource SurfaceBrush}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Padding="10"/>
                        </TabItem>
                        <TabItem Header="Readiness">
                            <Grid Background="{StaticResource BackgroundBrush}">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0"
                                           Text="{Binding ReadinessStatus}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontWeight="SemiBold"
                                           Margin="10,8"/>
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding CompatibilityIssues}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          Margin="8">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="100"/>
                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="150"/>
                                        <DataGridTextColumn Header="Position" Binding="{Binding Position}" Width="260"/>
                                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════
                 4. MODEL INFO  – what the tool assumed / translated
                    • Translation Warnings: constructs that couldn't
                      be perfectly mapped (stubs, unknown calls, etc.)
                    • Variable Domains: the value ranges used for each
                      parameter — edit Min/Max before regenerating
                 ═══════════════════════════════════════════════════ -->
            <TabItem Header="Model Info">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox Grid.Row="0" Header="Translation Warnings" Foreground="White" Margin="8">
                        <DataGrid ItemsSource="{Binding Assumptions}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="150" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Symbol" Binding="{Binding SymbolName}" Width="220" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Location" Binding="{Binding Location}" Width="220" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>

                    <GroupBox Grid.Row="1" Header="Variable Domains  (edit Min / Max then re-generate to apply)" Foreground="White" Margin="8">
                        <DataGrid ItemsSource="{Binding Domains}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="260"/>
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="90"/>
                                <DataGridTextColumn Header="Min" Binding="{Binding Min}" Width="80"/>
                                <DataGridTextColumn Header="Max" Binding="{Binding Max}" Width="80"/>
                                <DataGridCheckBoxColumn Header="Bool" Binding="{Binding IsBoolean}" Width="70"/>
                                <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </GroupBox>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════
                 5. REQUIREMENTS  – natural-language → CTL queries
                 ═══════════════════════════════════════════════════ -->
            <TabItem Header="Requirements">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="180"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Background="{StaticResource PrimaryMidBrush}">
                        <Button Content="Interpret Requirements"
                                Command="{Binding InterpretRequirementsCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="8"/>
                        <Button Content="Load from File"
                                Command="{Binding LoadRequirementsFromFileCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="4"
                                ToolTip="Load requirements text from a .txt or .md file"/>
                        <TextBlock Text="Type requirements in plain English, then click Interpret Requirements to generate CTL queries."
                                   Foreground="#AAA"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="12,0"/>
                    </StackPanel>

                    <TextBox Grid.Row="1"
                             FontFamily="Consolas"
                             FontSize="13"
                             Text="{Binding RequirementsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             Background="{StaticResource SurfaceBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             Padding="10"
                             Margin="8"/>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding GeneratedQueries}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Margin="8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="170"/>
                            <DataGridTextColumn Header="Formula" Binding="{Binding Formula}" Width="360"/>
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="90" IsReadOnly="True"/>
                            <DataGridCheckBoxColumn Header="Valid" Binding="{Binding IsValidated}" Width="70" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Comment" Binding="{Binding Comment}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════
                 6. CFG VISUALIZATION  – only checked functions shown
                 ═══════════════════════════════════════════════════ -->
            <TabItem Header="CFG Visualization">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                               Orientation="Horizontal"
                               Background="{StaticResource PrimaryMidBrush}"
                               Height="44">
                        <Button Content="Generate CFG"
                                Command="{Binding GenerateCfgCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="8,6"/>
                        <Button Content="Export PNG"
                                Command="{Binding ExportCfgPngCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="4,6"/>
                        <Separator Margin="8,8" Background="{StaticResource BorderBrush}" Width="1"/>
                        <TextBlock Text="Method:"
                                 VerticalAlignment="Center"
                                 Margin="8,0,6,0"
                                 Foreground="White"
                                 FontWeight="SemiBold"
                                 FontSize="13"/>
                        <!-- Only functions checked in the Functions tab appear here -->
                        <ComboBox ItemsSource="{Binding SelectedMethods}"
                                SelectedItem="{Binding SelectedMethod}"
                                DisplayMemberPath="Name"
                                Width="220"
                                VerticalAlignment="Center"
                                Margin="0,6"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>

                        <ScrollViewer Grid.Column="0"
                                    HorizontalScrollBarVisibility="Auto"
                                    VerticalScrollBarVisibility="Auto"
                                    Background="#1A1A1E">
                            <Border Background="#1E1E24"
                                   Margin="16"
                                   BorderBrush="{StaticResource AccentBrush}"
                                   BorderThickness="1"
                                   CornerRadius="4">
                                <Canvas x:Name="CfgCanvas"
                                       Width="900"
                                       Height="700"
                                       Background="#1E1E24"/>
                            </Border>
                        </ScrollViewer>

                        <!-- Legend panel -->
                        <Border Grid.Column="1"
                                Background="{StaticResource PrimaryMidBrush}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1,0,0,0"
                                Padding="12,16">
                            <StackPanel>
                                <TextBlock Text="Legend"
                                           Foreground="White"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           Margin="0,0,0,12"/>

                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Ellipse Width="18" Height="12" Fill="#27AE60" Margin="0,0,8,0"/>
                                    <TextBlock Text="Entry" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Ellipse Width="18" Height="12" Fill="#C03939" Margin="0,0,8,0"/>
                                    <TextBlock Text="Exit" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Polygon Fill="#2980B9" Margin="0,0,8,0"
                                             Points="9,0 18,6 9,12 0,6"/>
                                    <TextBlock Text="Condition" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Polygon Fill="#8E44AD" Margin="0,0,8,0"
                                             Points="9,0 18,6 9,12 0,6"/>
                                    <TextBlock Text="Loop" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Rectangle Width="18" Height="12" Fill="#D35400" RadiusX="2" RadiusY="2" Margin="0,0,8,0"/>
                                    <TextBlock Text="Return" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <Rectangle Width="18" Height="12" Fill="#3E3E42" RadiusX="2" RadiusY="2"
                                               Stroke="#64A0DC" StrokeThickness="1" Margin="0,0,8,0"/>
                                    <TextBlock Text="Statement" Foreground="#CCC" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>

                                <Separator Background="{StaticResource BorderBrush}" Margin="0,12"/>

                                <TextBlock Text="Tips"
                                           Foreground="White"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="Only functions checked in the Functions tab appear in the dropdown."
                                           Foreground="#999"
                                           FontSize="10"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════
                 7. ANALYSIS  – complexity metrics per function
                 ═══════════════════════════════════════════════════ -->
            <TabItem Header="Analysis">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                               Orientation="Horizontal"
                               Background="{StaticResource PrimaryMidBrush}">
                        <Button Content="Run Analysis"
                                Command="{Binding RunAnalysisCommand}"
                                Style="{StaticResource WhiteButtonStyle}"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Only checked functions shown -->
                        <ListBox Grid.Column="0"
                               ItemsSource="{Binding SelectedMethods}"
                               SelectedItem="{Binding SelectedMethod}"
                               Background="{StaticResource BackgroundBrush}"
                               Foreground="{StaticResource TextPrimaryBrush}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="8">
                                        <TextBlock Text="{Binding Name}"
                                                 FontWeight="Bold"
                                                 FontSize="14"
                                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding ReturnType}"
                                                 FontStyle="Italic"
                                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="Complexity: "
                                                     FontWeight="SemiBold"
                                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding Complexity.CyclomaticComplexity}"
                                                     FontWeight="Bold"
                                                     Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Column="1"
                              BorderBrush="{StaticResource BorderBrush}"
                              BorderThickness="1,0,0,0"
                              Background="{StaticResource SurfaceBrush}">
                            <ScrollViewer>
                                <StackPanel Margin="16" DataContext="{Binding SelectedMethod}">
                                    <TextBlock Text="Method Details"
                                             FontSize="18"
                                             FontWeight="Bold"
                                             Margin="0,0,0,16"
                                             Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,10">
                                            <Run Text="Name: "
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <Run Text="{Binding Name, Mode=OneWay}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,10">
                                            <Run Text="Return Type: "
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <Run Text="{Binding ReturnType, Mode=OneWay}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,10">
                                            <Run Text="Cyclomatic Complexity: "
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <Run Text="{Binding Complexity.CyclomaticComplexity, Mode=OneWay}"
                                                 FontWeight="Bold"
                                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,10">
                                            <Run Text="Lines of Code: "
                                                 FontWeight="SemiBold"
                                                 Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <Run Text="{Binding LinesOfCode, Mode=OneWay}"
                                                 Foreground="{StaticResource TextPrimaryBrush}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════
                 8. LAYOUT FIXER  – clean up messy UPPAAL XML
                 ═══════════════════════════════════════════════════ -->
            <TabItem Header="Layout Fixer">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                               Orientation="Horizontal"
                               Background="{StaticResource PrimaryMidBrush}">
                        <Button Content="Load XML File"
                                Command="{Binding LoadLayoutInputCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                ToolTip="Open a UPPAAL XML file to fix"/>
                        <Button Content="Fix Layout"
                                Command="{Binding FixLayoutCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                ToolTip="Re-compute positions for the input XML"/>
                        <Button Content="Export Fixed XML"
                                Command="{Binding ExportFixedLayoutCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                ToolTip="Save the corrected XML to a file"/>
                        <Separator Margin="8,0" Background="White" Width="2"/>
                        <Button Content="Clear"
                                Command="{Binding ClearLayoutCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                ToolTip="Clear both panels"/>
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <DockPanel Grid.Column="0">
                            <TextBlock DockPanel.Dock="Top"
                                     Text="Input XML (paste or load a jumbled UPPAAL model)"
                                     FontWeight="SemiBold" Foreground="White"
                                     Margin="8,6,8,4"/>
                            <TextBox FontFamily="Consolas" FontSize="12"
                                   Text="{Binding LayoutInputXml, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                   AcceptsReturn="True" AcceptsTab="True"
                                   VerticalScrollBarVisibility="Auto"
                                   HorizontalScrollBarVisibility="Auto"
                                   Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                   Padding="10" Margin="4"/>
                        </DockPanel>

                        <TextBlock Grid.Column="1" Text="➜"
                                 FontSize="28" FontWeight="Bold"
                                 Foreground="{StaticResource PrimaryMidBrush}"
                                 VerticalAlignment="Center"
                                 Margin="6,0"/>

                        <DockPanel Grid.Column="2">
                            <TextBlock DockPanel.Dock="Top"
                                     Text="Output XML (fixed layout)"
                                     FontWeight="SemiBold" Foreground="White"
                                     Margin="8,6,8,4"/>
                            <TextBox FontFamily="Consolas" FontSize="12"
                                   Text="{Binding LayoutOutputXml, Mode=TwoWay}"
                                   AcceptsReturn="True" AcceptsTab="True"
                                   VerticalScrollBarVisibility="Auto"
                                   HorizontalScrollBarVisibility="Auto"
                                   IsReadOnly="True"
                                   Background="{StaticResource SurfaceBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                   Padding="10" Margin="4"/>
                        </DockPanel>
                    </Grid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2"
                  Background="{StaticResource PrimaryDarkBrush}"
                  Foreground="White"
                  Height="30">
            <StatusBarItem>
                <TextBlock Foreground="White">
                    <Run Text="Status: "/>
                    <Run Text="{Binding StatusMessage}" FontWeight="SemiBold"/>
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <ProgressBar Width="120" Height="18"
                           IsIndeterminate="{Binding IsBusy}"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                           Foreground="#FFD700"/>
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Foreground="White">
                    <Run Text="Project: "/>
                    <Run Text="{Binding CurrentProjectName}" FontWeight="SemiBold"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
