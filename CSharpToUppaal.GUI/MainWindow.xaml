<Window x:Class="CSharpToUppaal.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CSharpToUppaal.GUI"
        xmlns:vm="clr-namespace:CSharpToUppaal.GUI.ViewModels"
        xmlns:controls="clr-namespace:CSharpToUppaal.GUI.Controls"
        xmlns:converters="clr-namespace:CSharpToUppaal.GUI.Converters"
        mc:Ignorable="d"
        Title="C# to UPPAAL Model Generator" 
        Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:NullToVisibilityConverter x:Key="NullToVis" />
        <converters:StatusToColorConverter x:Key="StatusToColor" />
        <converters:BoolToStringConverter x:Key="BoolToStringConverter" />
        
        <!-- Button Style with White Foreground -->
        <Style x:Key="WhiteButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryMidBrush}"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Simplified Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryDarkBrush}" Padding="12">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" 
                          Text="C# to UPPAAL Model Generator" 
                          FontSize="20" FontWeight="Bold" 
                          Foreground="White" 
                          VerticalAlignment="Center" 
                          Margin="8,0"/>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Settings" 
                            Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource WhiteButtonStyle}"
                            Margin="8,0"/>
                    <Button Content="Clear All" 
                            Command="{Binding ClearAllCommand}"
                            Style="{StaticResource WhiteButtonStyle}"
                            Margin="8,0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content Area (No Left Panel) -->
        <TabControl Grid.Row="1" 
                   Background="{StaticResource BackgroundBrush}"
                   BorderThickness="0">

            <!-- Code Editor Tab -->
            <TabItem Header="Code Editor">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar with white buttons -->
                    <StackPanel Grid.Row="0" 
                               Orientation="Horizontal" 
                               Background="{StaticResource PrimaryMidBrush}">
                        <Button Content="Load File" 
                                Command="{Binding LoadFileCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="8"/>
                        <Button Content="Parse" 
                                Command="{Binding ParseCodeCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="4"/>
                        <Button Content="Clear All" 
                                Command="{Binding ClearCodeCommand}"
                                Style="{StaticResource WhiteButtonStyle}"
                                Margin="4"/>
                    </StackPanel>

                    <controls:CodeEditor Grid.Row="1" 
                                       Text="{Binding SourceCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>

            <!-- CFG Visualization Tab -->
            <TabItem Header="CFG Visualization">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar with white buttons -->
                    <StackPanel Grid.Row="0" 
                               Orientation="Horizontal" 
                               Background="{StaticResource PrimaryMidBrush}"
                               >
                        <Button Content="Generate CFG" 
                                Command="{Binding GenerateCfgCommand}"
                                Style="{StaticResource WhiteButtonStyle}"/>
                        <Button Content="Export CFG (PNG)" 
                                Command="{Binding ExportCfgPngCommand}"
                                Style="{StaticResource WhiteButtonStyle}"/>
                        <Separator Margin="8,0" Background="White" Width="2"/>
                        <TextBlock Text="Method:" 
                                 VerticalAlignment="Center" 
                                 Margin="8,0"
                                 Foreground="White"
                                 FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding Methods}" 
                                SelectedItem="{Binding SelectedMethod}"
                                DisplayMemberPath="Name" 
                                Width="250"
                                VerticalAlignment="Center"
                                Background="White"
                                Foreground="Black">
                            <ComboBox.ItemContainerStyle>
                                <Style TargetType="ComboBoxItem">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="Black"/>
                                </Style>
                            </ComboBox.ItemContainerStyle>
                        </ComboBox>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" 
                                HorizontalScrollBarVisibility="Auto" 
                                VerticalScrollBarVisibility="Auto"
                                Background="#F5F5F5">
                        <Border Background="White" 
                               Margin="20" 
                               BorderBrush="#CCCCCC" 
                               BorderThickness="1"
                               CornerRadius="4">
                            <Canvas x:Name="CfgCanvas" 
                                   Width="800" 
                                   Height="600" 
                                   Background="White"/>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- UPPAAL Model Tab -->
            <TabItem Header="UPPAAL Model">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar with white buttons -->
                    <StackPanel Grid.Row="0" 
                               Orientation="Horizontal" 
                               Background="{StaticResource PrimaryMidBrush}"
                               >
                        <Button Content="Generate UPPAAL Model" 
                                Command="{Binding GenerateModelCommand}"
                                Style="{StaticResource WhiteButtonStyle}"/>
                        <Button Content="Export" 
                                Command="{Binding ExportModelCommand}"
                                Style="{StaticResource WhiteButtonStyle}"/>
                        <Separator Margin="8,0" Background="White" Width="2"/>
                        <TextBlock Text="Model Name:" 
                                 VerticalAlignment="Center" 
                                 Margin="8,0"
                                 Foreground="White"
                                 FontWeight="SemiBold"/>
                        <TextBox Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}" 
                               Width="200"
                               VerticalAlignment="Center"
                               Padding="6,4"
                               Background="White"
                               Foreground="Black"/>
                    </StackPanel>

                    <TabControl Grid.Row="1" 
                               Background="{StaticResource BackgroundBrush}"
                               BorderThickness="0">
                        <!-- XML View -->
                        <TabItem Header="XML View">
                            <TextBox FontFamily="Consolas" 
                                   FontSize="12"
                                   Text="{Binding UppaalXml, Mode=TwoWay}"
                                   AcceptsReturn="True" 
                                   AcceptsTab="True"
                                   VerticalScrollBarVisibility="Auto"
                                   HorizontalScrollBarVisibility="Auto"
                                   IsReadOnly="{Binding IsXmlReadOnly}"
                                   Background="White"
                                   Foreground="Black"
                                   Padding="10"/>
                        </TabItem>
                        <!-- Visual Preview -->
                        <TabItem Header="Visual Preview">
                            <ScrollViewer Background="White" 
                                        HorizontalScrollBarVisibility="Auto" 
                                        VerticalScrollBarVisibility="Auto">
                                <Border Background="White" 
                                       Margin="20" 
                                       BorderBrush="#CCCCCC" 
                                       BorderThickness="1"
                                       CornerRadius="4">
                                    <Canvas x:Name="UppaalCanvas" 
                                           Background="White"/>
                                </Border>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </Grid>
            </TabItem>

            <!-- Verification Results Tab -->
            <TabItem Header="Verification">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar with white buttons -->
                    <StackPanel Grid.Row="0" 
                               Orientation="Horizontal" 
                               Background="{StaticResource PrimaryMidBrush}"
                               >
                        <Button Content="Run Verification" 
                                Command="{Binding RunVerificationCommand}"
                                Style="{StaticResource WhiteButtonStyle}"/>
                        <Button Content="Clear Results" 
                                Command="{Binding ClearVerificationCommand}"
                                Style="{StaticResource WhiteButtonStyle}"/>
                        <Separator Margin="8,0" Background="White" Width="2"/>
                        <TextBlock Text="Status:" 
                                 VerticalAlignment="Center" 
                                 Margin="8,0"
                                 Foreground="White"
                                 FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding VerificationStatus}" 
                                 VerticalAlignment="Center" 
                                 FontWeight="Bold" 
                                 Margin="8,0"
                                 Foreground="#FFD700"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" 
                            ItemsSource="{Binding VerificationResults}"
                            AutoGenerateColumns="False" 
                            IsReadOnly="True"
                            Background="White"
                            Foreground="Black"
                            AlternatingRowBackground="#F9F9F9"
                            GridLinesVisibility="Horizontal"
                            HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Property" Binding="{Binding Name}" Width="150"/>
                            <DataGridTextColumn Header="Formula" Binding="{Binding Formula}" Width="300"/>
                            <DataGridCheckBoxColumn Header="Verified" Binding="{Binding IsVerified}" Width="80"/>
                            <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="200"/>
                            <DataGridTextColumn Header="Time" Width="80">
                                <DataGridTextColumn.Binding>
                                    <Binding Path="VerificationTime" StringFormat="{}{0:mm\\:ss\\.fff}"/>
                                </DataGridTextColumn.Binding>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Error" Binding="{Binding ErrorMessage}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Analysis Results Tab -->
            <TabItem Header="Analysis">
                <Grid Background="{StaticResource BackgroundBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar with white buttons -->
                    <StackPanel Grid.Row="0" 
                               Orientation="Horizontal" 
                               Background="{StaticResource PrimaryMidBrush}"
                               >
                        <Button Content="Run Analysis" 
                                Command="{Binding RunAnalysisCommand}"
                                Style="{StaticResource WhiteButtonStyle}"/>
                    </StackPanel>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <ListBox Grid.Column="0" 
                               ItemsSource="{Binding Methods}"
                               SelectedItem="{Binding SelectedMethod}"
                               Background="White"
                               Foreground="Black">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="8">
                                        <TextBlock Text="{Binding Name}" 
                                                 FontWeight="Bold"
                                                 FontSize="14"
                                                 Foreground="#2C3E50"/>
                                        <TextBlock Text="{Binding ReturnType}" 
                                                 FontStyle="Italic"
                                                 Foreground="#7F8C8D"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="Complexity: " 
                                                     FontWeight="SemiBold"
                                                     Foreground="#34495E"/>
                                            <TextBlock Text="{Binding Complexity.CyclomaticComplexity}"
                                                     FontWeight="Bold"
                                                     Foreground="#E74C3C"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Column="1" 
                              BorderBrush="#CCCCCC" 
                              BorderThickness="1,0,0,0"
                              Background="White">
                            <ScrollViewer>
                                <StackPanel Margin="16" DataContext="{Binding SelectedMethod}">
                                    <TextBlock Text="Method Details" 
                                             FontSize="18" 
                                             FontWeight="Bold" 
                                             Margin="0,0,0,16"
                                             Foreground="#2C3E50"/>
                                    <StackPanel>
                                        <TextBlock Margin="0,0,0,10">
                                            <Run Text="Name: " 
                                                 FontWeight="SemiBold" 
                                                 Foreground="#34495E"/>
                                            <Run Text="{Binding Name, Mode=OneWay}"
                                                 Foreground="#2C3E50"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,10">
                                            <Run Text="Return Type: " 
                                                 FontWeight="SemiBold"
                                                 Foreground="#34495E"/>
                                            <Run Text="{Binding ReturnType, Mode=OneWay}"
                                                 Foreground="#2C3E50"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,10">
                                            <Run Text="Cyclomatic Complexity: " 
                                                 FontWeight="SemiBold"
                                                 Foreground="#34495E"/>
                                            <Run Text="{Binding Complexity.CyclomaticComplexity, Mode=OneWay}"
                                                 FontWeight="Bold"
                                                 Foreground="#E74C3C"/>
                                        </TextBlock>
                                        <TextBlock Margin="0,0,0,10">
                                            <Run Text="Lines of Code: " 
                                                 FontWeight="SemiBold"
                                                 Foreground="#34495E"/>
                                            <Run Text="{Binding LinesOfCode, Mode=OneWay}"
                                                 Foreground="#2C3E50"/>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" 
                  Background="{StaticResource PrimaryDarkBrush}" 
                  Foreground="White"
                  Height="30">
            <StatusBarItem>
                <TextBlock Foreground="White">
                    <Run Text="Status: "/>
                    <Run Text="{Binding StatusMessage}" FontWeight="SemiBold"/>
                </TextBlock>
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <ProgressBar Width="120" Height="18" 
                           IsIndeterminate="{Binding IsBusy}"
                           Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                           Foreground="#FFD700"/>
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Foreground="White">
                    <Run Text="Project: "/>
                    <Run Text="{Binding CurrentProjectName}" FontWeight="SemiBold"/>
                </TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
