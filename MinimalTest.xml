<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE nta PUBLIC "-//Uppaal Team//DTD Flat System 1.6//EN" "http://www.it.uu.se/research/group/darts/uppaal/flat-1_6.dtd">
<nta>
  <declaration>
// Global declarations
  </declaration>
  <template>
    <name>SimpleProcess</name>
    <declaration>
int x;
    </declaration>
    <location id="id0" x="0" y="0">
      <name x="-10" y="-30">Start</name>
    </location>
    <location id="id1" x="200" y="0">
      <name x="190" y="-30">End</name>
    </location>
    <init ref="id0" />
    <transition>
      <source ref="id0" />
      <target ref="id1" />
    </transition>
  </template>
  <system>system SimpleProcess;</system>
  <queries>
    <query>
      <formula>A[] not deadlock</formula>
      <comment>Check deadlock freedom</comment>
    </query>
  </queries>
</nta>
